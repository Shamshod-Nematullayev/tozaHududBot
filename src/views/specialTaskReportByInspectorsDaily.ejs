<!DOCTYPE html>
<html lang="uz">

<head>
  <meta charset="UTF-8" />
  <title>Inspectorlar bo‘yicha kunlik hisobot</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f7f7f7;
      padding: 20px;
    }

    h1 {
      text-align: center;
      margin-bottom: 20px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
    }

    th,
    td {
      border: 1px solid #ddd;
      padding: 10px;
      text-align: center;
    }

    th {
      background-color: #2c3e50;
      color: #fff;
    }

    tr:nth-child(even) {
      background-color: #f2f2f2;
    }

    .percent {
      font-weight: bold;
    }

    .low {
      color: #e74c3c;
    }

    .medium {
      color: #f39c12;
    }

    .high {
      color: #27ae60;
    }
  </style>
</head>

<body>
  <h1>Maxsus topshiriq <%=type == "phone" ? "Telefon 📞" : "Elektr ⚡️"%> bo‘yicha kunlik hisobot</h1>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Inspector</th>
        <th>Jami topshiriqlar</th>
        <th>Bajarilgan</th>
        <th>Bajarilish %</th>
        <th>Bugun bajarilgan</th>
      </tr>
    </thead>

    <tbody>
      <% result.forEach((item, index) => { 
          let percentClass = 'low';
          if (item.complatedPercent >= 70) percentClass = 'high';
          else if (item.complatedPercent >= 40) percentClass = 'medium';
      %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= item.inspectorName %></td>
        <td><%= item.allTasksCount %></td>
        <td><%= item.complatedTasksCount %></td>
        <td class="percent <%= percentClass %>">
          <%= item.complatedPercent.toFixed(1) %> %
        </td>
        <td><%= item.todayCompleted %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</body>

</html>